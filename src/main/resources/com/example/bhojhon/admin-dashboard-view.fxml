<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="25.0" alignment="TOP_CENTER" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.bhojhon.controller.AdminDashboardController" styleClass="content-container" style="-fx-background-color: #f5f5f5;">
    <padding>
        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0"/>
    </padding>

    <!-- Header Section -->
    <HBox alignment="CENTER_LEFT" spacing="20.0">
        <Label text="Admin Dashboard - All Orders" styleClass="page-title" style="-fx-text-fill: #2c3e50; -fx-font-weight: bold; -fx-font-size: 26px;">
            <font>
                <Font name="Arial Bold" size="26.0"/>
            </font>
        </Label>
        <HBox HBox.hgrow="ALWAYS"/>
        <Button text="Refresh" onAction="#loadData" styleClass="secondary-button" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5px; -fx-padding: 6 15 6 15;"/>
        <Button text="Logout" onAction="#handleLogout" styleClass="link-button" style="-fx-background-color: transparent; -fx-text-fill: #e74c3c; -fx-underline: true; -fx-font-weight: bold; -fx-cursor: hand;"/>
    </HBox>

    <!-- Orders Table -->
    <TableView fx:id="ordersTable" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);">
        <columns>
            <TableColumn fx:id="orderIdCol" text="Order ID" prefWidth="100.0"/>
            <TableColumn fx:id="nameCol" text="Passenger" prefWidth="120.0"/>
            <TableColumn fx:id="phoneCol" text="Phone" prefWidth="110.0"/>
            <TableColumn fx:id="trainCol" text="Train" prefWidth="70.0"/>
            <TableColumn fx:id="seatCol" text="Seat" prefWidth="70.0"/>
            <TableColumn fx:id="stationCol" text="Station" prefWidth="100.0"/>
            <TableColumn fx:id="itemsCol" text="Items Ordered" prefWidth="200.0"/>
            <TableColumn fx:id="totalCol" text="Total" prefWidth="80.0"/>
            <TableColumn fx:id="dateCol" text="Order Date" prefWidth="130.0"/>
        </columns>
    </TableView>
</VBox>