<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="25.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.bhojhon.controller.RestaurantDashboardController"
      style="-fx-background-color: #f5f5f5; -fx-padding: 30;">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="20.0">
        <Button text="← Logout" onAction="#handleBack"
                style="-fx-background-color: white; -fx-border-color: #bdc3c7; -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-weight: bold; -fx-cursor: hand;"/>

        <Region HBox.hgrow="ALWAYS"/>

        <VBox alignment="CENTER_RIGHT">
            <Label fx:id="restaurantNameLabel" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Label fx:id="stationLabel" style="-fx-text-fill: #666;"/>
        </VBox>
    </HBox>

    <Separator/>

    <!-- Main Content -->
    <HBox spacing="30.0" VBox.vgrow="ALWAYS">

        <!-- Current Menu Table -->
        <VBox spacing="15.0" HBox.hgrow="ALWAYS">
            <Label text="Current Menu" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <TableView fx:id="menuTableView" VBox.vgrow="ALWAYS"
                       style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #ddd;">
                <columns>
                    <TableColumn fx:id="imageColumn" text="Image" prefWidth="80"/>
                    <TableColumn fx:id="nameColumn" text="Item Name" prefWidth="150"/>
                    <TableColumn fx:id="categoryColumn" text="Category" prefWidth="100"/>
                    <TableColumn fx:id="priceColumn" text="Price" prefWidth="80" style="-fx-alignment: CENTER-RIGHT;"/>
                    <TableColumn fx:id="actionColumn" text="Action" prefWidth="100"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
        </VBox>

        <!-- Add Item Form -->
        <VBox spacing="15.0" prefWidth="350.0" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 8,0,0,4);">
            <Label text="Add New Item" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

            <VBox spacing="8.0">
                <Label text="Item Name" style="-fx-font-weight: bold;"/>
                <TextField fx:id="nameField" promptText="Enter item name"
                           style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-padding: 6;"/>
            </VBox>

            <VBox spacing="8.0">
                <Label text="Category" style="-fx-font-weight: bold;"/>
                <ComboBox fx:id="categoryComboBox" promptText="Select Category" maxWidth="Infinity"
                          style="-fx-background-radius: 6; -fx-border-radius: 6;"/>
            </VBox>

            <VBox spacing="8.0">
                <Label text="Price (BDT)" style="-fx-font-weight: bold;"/>
                <TextField fx:id="priceField" promptText="e.g. 250" style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-padding: 6;"/>
            </VBox>

            <VBox spacing="8.0">
                <Label text="Description" style="-fx-font-weight: bold;"/>
                <TextArea fx:id="descriptionField" promptText="Enter short description" prefHeight="80" wrapText="true"
                          style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-padding: 8;"/>
            </VBox>

            <VBox spacing="8.0">
                <Label text="Item Image" style="-fx-font-weight: bold;"/>
                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <Button text="Choose File" onAction="#handleUploadImage" prefWidth="120"
                            style="-fx-background-radius: 6; -fx-border-radius: 6; -fx-border-color: #bdc3c7; -fx-cursor: hand;"/>
                    <Label fx:id="fileNameLabel" text="No file selected" style="-fx-font-size: 12px; -fx-text-fill: #555;" wrapText="true"/>
                </HBox>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <Button text="Add Item to Menu" onAction="#handleAddFoodItem" prefWidth="Infinity" prefHeight="40"
                    style="-fx-background-color: #1a73e8; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-font-size: 15px; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(26,115,232,0.3), 5,0,0,2);"/>

            <Label fx:id="errorLabel" textFill="red" style="-fx-font-size: 12px;" wrapText="true"/>
        </VBox>
    </HBox>
</VBox>