<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane
    xmlns="http://javafx.com/javafx/17"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.example.bhojhon.controller.RestaurantDashboardController"
    styleClass="rd-root">

    <!-- ═══════════════════════════════════════════════════════ -->
    <!--  LEFT SIDEBAR                                           -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <left>
        <VBox styleClass="rd-sidebar" spacing="4.0" minWidth="210.0" maxWidth="210.0">
            <padding>
                <Insets top="28.0" bottom="24.0" left="14.0" right="14.0"/>
            </padding>

            <!-- Brand -->
            <VBox spacing="3.0">
                <padding><Insets bottom="26.0"/></padding>
                <Label text="🍽️  BhojhOn" styleClass="rd-brand-title"/>
                <Label text="Restaurant Portal" styleClass="rd-brand-sub"/>
            </VBox>

            <!-- Nav: Dashboard -->
            <HBox styleClass="rd-nav-item rd-nav-active" alignment="CENTER_LEFT" spacing="12.0">
                <Label text="⊞" styleClass="rd-nav-icon"/>
                <Label text="Dashboard" styleClass="rd-nav-label"/>
            </HBox>

            <!-- Nav: Manage Menu -->
            <HBox styleClass="rd-nav-item" alignment="CENTER_LEFT" spacing="12.0">
                <Label text="📋" styleClass="rd-nav-icon"/>
                <Label text="Manage Menu" styleClass="rd-nav-label"/>
            </HBox>

<!--            &lt;!&ndash; Nav: Orders &ndash;&gt;-->
<!--            <HBox styleClass="rd-nav-item" alignment="CENTER_LEFT" spacing="12.0">-->
<!--                <Label text="📦" styleClass="rd-nav-icon"/>-->
<!--                <Label text="Orders" styleClass="rd-nav-label"/>-->
<!--            </HBox>-->

<!--            &lt;!&ndash; Nav: Profile &ndash;&gt;-->
<!--            <HBox styleClass="rd-nav-item" alignment="CENTER_LEFT" spacing="12.0">-->
<!--                <Label text="👤" styleClass="rd-nav-icon"/>-->
<!--                <Label text="Profile" styleClass="rd-nav-label"/>-->
<!--            </HBox>-->

            <!-- Spacer -->
            <Region VBox.vgrow="ALWAYS"/>

            <!-- Divider -->
            <Region styleClass="rd-divider" maxHeight="1.0" minHeight="1.0"/>

            <!-- Logout -->
            <HBox styleClass="rd-nav-item rd-nav-logout" alignment="CENTER_LEFT" spacing="12.0"
                  onMouseClicked="#handleBack" style="-fx-cursor: hand;">
                <Label text="⏻" styleClass="rd-nav-icon"/>
                <Label text="Logout" styleClass="rd-nav-label"/>
            </HBox>
        </VBox>
    </left>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!--  CENTER: Header + Main Content                          -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <center>
        <VBox styleClass="rd-content-area" spacing="0.0">

            <!-- ── HEADER BAR ── -->
            <HBox styleClass="rd-header" alignment="CENTER_LEFT" spacing="16.0">
                <VBox spacing="2.0">
                    <Label text="Restaurant Dashboard" styleClass="rd-header-title"/>
                    <Label text="Manage your menu and track performance" styleClass="rd-header-sub"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <!-- Restaurant name from session -->
                <VBox alignment="CENTER_RIGHT" spacing="2.0">
                    <Label fx:id="restaurantNameLabel" text="" styleClass="rd-restaurant-name"/>
                    <Label fx:id="stationLabel" text="" styleClass="rd-station-label"/>
                </VBox>
                <HBox styleClass="rd-avatar" alignment="CENTER" minWidth="36.0" minHeight="36.0">
                    <Label text="R" styleClass="rd-avatar-label"/>
                </HBox>
            </HBox>

            <!-- ── SCROLLABLE MAIN AREA ── -->
            <VBox VBox.vgrow="ALWAYS" styleClass="rd-scroll-area" spacing="22.0">
                <padding>
                    <Insets top="22.0" right="26.0" bottom="26.0" left="26.0"/>
                </padding>

                <!-- ─ SECTION HEADING ─ -->
                <VBox spacing="2.0">
                    <Label text="Menu Management" styleClass="rd-section-title"/>
                    <Label text="Add new items and view your current menu" styleClass="rd-section-sub"/>
                </VBox>

                <!-- ─ MAIN CONTENT: Table + Add Form ─ -->
                <HBox spacing="22.0" VBox.vgrow="ALWAYS">

                    <!-- ── MENU TABLE SIDE ── -->
                    <VBox spacing="14.0" HBox.hgrow="ALWAYS">

                        <!-- Table toolbar -->
                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                            <Label text="Current Menu" styleClass="rd-panel-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="⟳  Refresh" onAction="#loadMenu" styleClass="rd-btn-secondary"/>
                        </HBox>

                        <!-- Menu table -->
                        <TableView fx:id="menuTableView" VBox.vgrow="ALWAYS"
                                   styleClass="rd-table" minHeight="350.0">
                            <columns>
                                <TableColumn fx:id="imageColumn"    text="Image"     prefWidth="75.0"/>
                                <TableColumn fx:id="nameColumn"     text="Item Name" prefWidth="160.0"/>
                                <TableColumn fx:id="categoryColumn" text="Category"  prefWidth="110.0"/>
                                <TableColumn fx:id="priceColumn"    text="Price (৳)" prefWidth="90.0"/>
                                <TableColumn fx:id="actionColumn"   text="Action"    prefWidth="90.0"/>
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                            </columnResizePolicy>
                        </TableView>
                    </VBox>

                    <!-- ── ADD ITEM FORM SIDE ── -->
                    <VBox styleClass="rd-form-card" spacing="14.0" minWidth="310.0" maxWidth="330.0">
                        <padding>
                            <Insets top="22.0" right="22.0" bottom="22.0" left="22.0"/>
                        </padding>

                        <Label text="Add New Item" styleClass="rd-panel-title"/>

                        <!-- Item Name -->
                        <VBox spacing="6.0">
                            <Label text="Item Name" styleClass="rd-form-label"/>
                            <TextField fx:id="nameField" promptText="Enter item name"
                                       styleClass="rd-text-field"/>
                        </VBox>

                        <!-- Category -->
                        <VBox spacing="6.0">
                            <Label text="Category" styleClass="rd-form-label"/>
                            <ComboBox fx:id="categoryComboBox" promptText="Select Category"
                                      maxWidth="Infinity" styleClass="rd-combo-box"/>
                        </VBox>

                        <!-- Price -->
                        <VBox spacing="6.0">
                            <Label text="Price (BDT)" styleClass="rd-form-label"/>
                            <TextField fx:id="priceField" promptText="e.g. 250"
                                       styleClass="rd-text-field"/>
                        </VBox>

                        <!-- Description -->
                        <VBox spacing="6.0">
                            <Label text="Description" styleClass="rd-form-label"/>
                            <TextArea fx:id="descriptionField" promptText="Enter short description"
                                      prefHeight="80.0" wrapText="true"
                                      styleClass="rd-text-area"/>
                        </VBox>

                        <!-- Image upload -->
                        <VBox spacing="6.0">
                            <Label text="Item Image" styleClass="rd-form-label"/>
                            <HBox spacing="10.0" alignment="CENTER_LEFT">
                                <Button text="📁  Choose File" onAction="#handleUploadImage"
                                        styleClass="rd-btn-secondary"/>
                                <Label fx:id="fileNameLabel" text="No file selected"
                                       styleClass="rd-file-label" wrapText="true"
                                       HBox.hgrow="ALWAYS"/>
                            </HBox>
                        </VBox>

                        <Region VBox.vgrow="ALWAYS"/>

                        <!-- Submit -->
                        <Button text="＋  Add Item to Menu" onAction="#handleAddFoodItem"
                                prefWidth="Infinity" prefHeight="42.0"
                                styleClass="rd-btn-primary"/>

                        <!-- Error label -->
                        <Label fx:id="errorLabel" text="" styleClass="rd-error-label"
                               wrapText="true"/>
                    </VBox>

                </HBox>
            </VBox>
            <!-- end main area -->

        </VBox>
    </center>

</BorderPane>