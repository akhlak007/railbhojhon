<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER"
      spacing="30.0"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.bhojhon.controller.SplashController"
      style="
            -fx-background-color: linear-gradient(to bottom right, #0f2027, #203a43, #2c5364);
            -fx-padding: 60;
            ">

    <!-- App Name -->
    <Label text="RailKhabar"
           style="
                -fx-text-fill: #ffffff;
                -fx-font-size: 54px;
                -fx-font-weight: bold;
                -fx-letter-spacing: 2px;
                -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 8, 0, 2, 2);
           "/>

    <!-- Tagline -->
    <Label text="Delicious Food on Your Train Journey"
           wrapText="true"
           style="
                -fx-text-fill: #c0dfff;
                -fx-font-size: 18px;
                -fx-opacity: 0.9;
                -fx-font-weight: medium;
           "/>

    <!-- Loader -->
    <VBox alignment="CENTER" spacing="12">
        <ProgressIndicator prefWidth="60"
                           prefHeight="60"
                           style="
                               -fx-progress-color: #00c6ff;
                           "/>

        <Label text="Loading..."
               style="
                    -fx-text-fill: #ffffff;
                    -fx-font-size: 14px;
                    -fx-opacity: 0.8;
               "/>
    </VBox>

</VBox>