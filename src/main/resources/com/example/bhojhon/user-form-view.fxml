<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER"
      spacing="25.0"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.bhojhon.controller.UserFormController"
      style="
            -fx-background-color: linear-gradient(to bottom right, #f8fbff, #e6f0f8);
            -fx-padding: 40;
            ">

    <!-- Card Container -->
    <VBox spacing="20"
          maxWidth="520"
          alignment="TOP_CENTER"
          style="
                -fx-background-color: white;
                -fx-background-radius: 18;
                -fx-padding: 35;
                -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 25, 0.3, 0, 6);
                ">

        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="15.0">
            <Button text="← Back"
                    onAction="#handleBack"
                    style="
                        -fx-background-color: transparent;
                        -fx-text-fill: #1a73e8;
                        -fx-font-size: 14px;
                        -fx-font-weight: bold;
                    "/>

            <Label text="Passenger Details"
                   style="
                        -fx-font-size: 26px;
                        -fx-font-weight: bold;
                        -fx-text-fill: #1f2937;
                   "/>
        </HBox>

        <Label text="Please fill in your contact information."
               style="
                    -fx-text-fill: #6b7280;
                    -fx-font-size: 14px;
               "/>

        <!-- Form Grid -->
        <GridPane hgap="15.0" vgap="18.0">

            <Label text="Full Name:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField fx:id="nameField"
                       promptText="Your Name"
                       GridPane.rowIndex="0" GridPane.columnIndex="1"
                       prefWidth="280"
                       style="-fx-background-radius: 8; -fx-border-radius: 8;"/>

            <Label text="Phone Number:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextField fx:id="phoneField"
                       promptText="01xxxxxxxxx"
                       GridPane.rowIndex="1" GridPane.columnIndex="1"
                       style="-fx-background-radius: 8; -fx-border-radius: 8;"/>

            <Label text="Email Address:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <TextField fx:id="emailField"
                       promptText="you@example.com"
                       GridPane.rowIndex="2" GridPane.columnIndex="1"
                       style="-fx-background-radius: 8; -fx-border-radius: 8;"/>

            <Label text="Seat Number:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <TextField fx:id="seatField"
                       promptText="Coach-Seat (e.g., G-42)"
                       GridPane.rowIndex="3" GridPane.columnIndex="1"
                       style="-fx-background-radius: 8; -fx-border-radius: 8;"/>

            <Label text="Delivery Info:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
            <TextField fx:id="deliveryNoteField"
                       promptText="Near the door, Blue bag"
                       GridPane.rowIndex="4" GridPane.columnIndex="1"
                       style="-fx-background-radius: 8; -fx-border-radius: 8;"/>

            <Label text="Ticket Number (PNR):" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
            <TextField fx:id="pnrField"
                       promptText="10-digit PNR"
                       GridPane.rowIndex="5" GridPane.columnIndex="1"
                       style="-fx-background-radius: 8; -fx-border-radius: 8;"/>

            <Label text="Train Number:" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
            <TextField fx:id="trainNumberField"
                       promptText="e.g. 701"
                       GridPane.rowIndex="6" GridPane.columnIndex="1"
                       style="-fx-background-radius: 8; -fx-border-radius: 8;"/>

            <Label text="Journey Date:" GridPane.rowIndex="7" GridPane.columnIndex="0"/>
            <TextField fx:id="journeyDateField"
                       promptText="DD-MM-YYYY"
                       GridPane.rowIndex="7" GridPane.columnIndex="1"
                       style="-fx-background-radius: 8; -fx-border-radius: 8;"/>

        </GridPane>

        <Label fx:id="errorLabel"
               textFill="#e53935"
               visible="false"
               style="-fx-font-weight: bold;"/>

        <!-- Primary Button -->
        <Button text="Continue to Ticket Upload"
                onAction="#handleSubmit"
                prefWidth="280"
                style="
                    -fx-background-color: linear-gradient(to right, #1a73e8, #0d47a1);
                    -fx-text-fill: white;
                    -fx-font-size: 15px;
                    -fx-font-weight: bold;
                    -fx-background-radius: 10;
                    -fx-padding: 12 20;
                "/>

    </VBox>

</VBox>