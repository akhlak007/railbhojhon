<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox
    xmlns="http://javafx.com/javafx/17"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.example.bhojhon.controller.UserFormController"
    style="-fx-background-color: linear-gradient(to bottom right, #eef3fb, #ddeaf7); -fx-padding: 30 40 40 40;"
    spacing="18">

    <!-- Back Button (outside card, top-left) -->
    <Button text="← Back"
            onAction="#handleBack"
            style="
                -fx-background-color: transparent;
                -fx-text-fill: #374151;
                -fx-font-size: 14px;
                -fx-font-weight: bold;
                -fx-cursor: hand;
                -fx-padding: 0;
            "/>

    <!-- Card -->
    <VBox
        spacing="22"
        maxWidth="520"
        alignment="TOP_CENTER"
        VBox.vgrow="ALWAYS"
        style="
            -fx-background-color: white;
            -fx-background-radius: 20;
            -fx-padding: 40 35 35 35;
            -fx-effect: dropshadow(gaussian, rgba(0,80,200,0.10), 28, 0.2, 0, 8);
        ">

        <!-- Title -->
        <VBox spacing="6" alignment="CENTER">
            <Label text="Passenger Details"
                   style="
                       -fx-font-size: 26px;
                       -fx-font-weight: bold;
                       -fx-text-fill: #111827;
                   "/>
            <Label text="Please review and confirm your information"
                   style="
                       -fx-font-size: 13px;
                       -fx-text-fill: #6b7280;
                   "/>
        </VBox>

        <!-- Form Fields -->
        <GridPane hgap="14" vgap="14">
            <columnConstraints>
                <ColumnConstraints percentWidth="50"/>
                <ColumnConstraints percentWidth="50"/>
            </columnConstraints>

            <!-- Row 0: Full Name | Phone Number -->
            <TextField fx:id="nameField"
                       promptText="👤  Full Name"
                       GridPane.rowIndex="0" GridPane.columnIndex="0"
                       style="
                           -fx-background-radius: 10;
                           -fx-border-radius: 10;
                           -fx-border-color: #d1d5db;
                           -fx-border-width: 1.2;
                           -fx-padding: 12 14;
                           -fx-font-size: 13.5px;
                           -fx-text-fill: #111827;
                           -fx-prompt-text-fill: #9ca3af;
                           -fx-background-color: white;
                       "/>
            <TextField fx:id="phoneField"
                       promptText="📞  Phone Number"
                       GridPane.rowIndex="0" GridPane.columnIndex="1"
                       style="
                           -fx-background-radius: 10;
                           -fx-border-radius: 10;
                           -fx-border-color: #d1d5db;
                           -fx-border-width: 1.2;
                           -fx-padding: 12 14;
                           -fx-font-size: 13.5px;
                           -fx-text-fill: #111827;
                           -fx-prompt-text-fill: #9ca3af;
                           -fx-background-color: white;
                       "/>

            <!-- Row 1: Email Address (full width) -->
            <TextField fx:id="emailField"
                       promptText="✉  Email Address"
                       GridPane.rowIndex="1" GridPane.columnIndex="0"
                       GridPane.columnSpan="2"
                       style="
                           -fx-background-radius: 10;
                           -fx-border-radius: 10;
                           -fx-border-color: #d1d5db;
                           -fx-border-width: 1.2;
                           -fx-padding: 12 14;
                           -fx-font-size: 13.5px;
                           -fx-text-fill: #111827;
                           -fx-prompt-text-fill: #9ca3af;
                           -fx-background-color: white;
                       "/>

            <!-- Row 2: Seat Number | Delivery Info -->
            <TextField fx:id="seatField"
                       promptText="🪑  Seat Number"
                       GridPane.rowIndex="2" GridPane.columnIndex="0"
                       style="
                           -fx-background-radius: 10;
                           -fx-border-radius: 10;
                           -fx-border-color: #d1d5db;
                           -fx-border-width: 1.2;
                           -fx-padding: 12 14;
                           -fx-font-size: 13.5px;
                           -fx-text-fill: #111827;
                           -fx-prompt-text-fill: #9ca3af;
                           -fx-background-color: white;
                       "/>
            <TextField fx:id="deliveryNoteField"
                       promptText="ℹ  Delivery Info"
                       GridPane.rowIndex="2" GridPane.columnIndex="1"
                       style="
                           -fx-background-radius: 10;
                           -fx-border-radius: 10;
                           -fx-border-color: #d1d5db;
                           -fx-border-width: 1.2;
                           -fx-padding: 12 14;
                           -fx-font-size: 13.5px;
                           -fx-text-fill: #111827;
                           -fx-prompt-text-fill: #9ca3af;
                           -fx-background-color: white;
                       "/>

            <!-- Row 3: Ticket (PNR) | Train Number -->
            <TextField fx:id="pnrField"
                       promptText="🎫  Ticket Number (PNR)"
                       GridPane.rowIndex="3" GridPane.columnIndex="0"
                       style="
                           -fx-background-radius: 10;
                           -fx-border-radius: 10;
                           -fx-border-color: #d1d5db;
                           -fx-border-width: 1.2;
                           -fx-padding: 12 14;
                           -fx-font-size: 13.5px;
                           -fx-text-fill: #111827;
                           -fx-prompt-text-fill: #9ca3af;
                           -fx-background-color: white;
                       "/>
            <TextField fx:id="trainNumberField"
                       promptText="⚡  Train Number"
                       GridPane.rowIndex="3" GridPane.columnIndex="1"
                       style="
                           -fx-background-radius: 10;
                           -fx-border-radius: 10;
                           -fx-border-color: #d1d5db;
                           -fx-border-width: 1.2;
                           -fx-padding: 12 14;
                           -fx-font-size: 13.5px;
                           -fx-text-fill: #111827;
                           -fx-prompt-text-fill: #9ca3af;
                           -fx-background-color: white;
                       "/>

            <!-- Row 4: Journey Date (full width, DatePicker) -->
            <DatePicker fx:id="journeyDatePicker"
                        promptText="Journey Date"
                        GridPane.rowIndex="4" GridPane.columnIndex="0"
                        GridPane.columnSpan="2"
                        maxWidth="Infinity"
                        style="
                            -fx-background-radius: 10;
                            -fx-border-radius: 10;
                            -fx-border-color: #3b82f6;
                            -fx-border-width: 1.5;
                            -fx-font-size: 13.5px;
                            -fx-text-fill: #111827;
                        "/>

            <!-- Hidden text field to keep existing controller logic intact -->
            <TextField fx:id="journeyDateField"
                       visible="false" managed="false"
                       GridPane.rowIndex="5" GridPane.columnIndex="0"/>

        </GridPane>

        <!-- Error label -->
        <Label fx:id="errorLabel"
               textFill="#dc2626"
               visible="false"
               style="-fx-font-size: 13px; -fx-font-weight: bold;"/>

        <!-- Submit Button -->
        <Button text="Continue to Ticket Upload"
                onAction="#handleSubmit"
                maxWidth="Infinity"
                style="
                    -fx-background-color: linear-gradient(to right, #3b82f6, #2563eb);
                    -fx-text-fill: white;
                    -fx-font-size: 15px;
                    -fx-font-weight: bold;
                    -fx-background-radius: 12;
                    -fx-padding: 14 20;
                    -fx-cursor: hand;
                    -fx-effect: dropshadow(gaussian, rgba(59,130,246,0.35), 12, 0.2, 0, 4);
                "/>

    </VBox>
</VBox>